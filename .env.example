#
# Copy this file to `.env` and fill in your own credentials.
# `.env` is git-ignored and must never be committed.

# HuggingFace access token (https://huggingface.co/settings/tokens)
HUGGINGFACE_TOKEN=

# Azure AI Foundry / OpenAI API key for the configured deployment
AZURE_AI_API_KEY=

# Azure AI endpoint, e.g. https://<resource-name>.services.ai.azure.com/
AZURE_AI_ENDPOINT=

# Google Gemini API key (only required when llm.provider is GEMINI)
GEMINI_API_KEY=
